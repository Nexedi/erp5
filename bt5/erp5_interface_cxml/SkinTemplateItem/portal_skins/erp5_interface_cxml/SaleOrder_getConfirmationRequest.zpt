<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE cXML SYSTEM "http://xml.cXML.org/schemas/cXML/1.2.060/Fulfill.dtd">
<tal:block xmlns:tal="http://xml.zope.org/namespaces/tal"
           tal:define="language string:de-DE;
                       cxml_url python:'%s/ERP5Site_cml' %here.getPortalObject().absolute_url();
                       order_request here/Order_getRelatedOrderRequestValue;
                       source_section here/getSourceSectionValue;
                       destination_section here/getDestinationSectionValue;
                       connector here/Base_getCxmlConnectorValueForSale;">
<cXML tal:attributes="xml:lang language; payloadID connector/getPayloadId; timestamp python:DateTime().ISO8601(); version connector/getCxmlVersion">
  <Header>
    <From>
      <Credential domain="NetworkID">
        <Identity tal:content="order_request/getTo"></Identity>
      </Credential>
    </From>
    <To>
      <Credential domain="NetworkID">
        <Identity tal:content="order_request/getFrom"></Identity>
      </Credential>
    </To>
    <Sender>
      <Credential domain="NetworkID">
        <Identity tal:content="here/Base_getCxmlUserIdForSale"></Identity>
        <SharedSecret>REPLACE_WITH_PASSWORD</SharedSecret>
      </Credential>
      <UserAgent tal:content="here/Base_getCxmlUserIdForSale"></UserAgent>
    </Sender>
  </Header>
  <Request tal:attributes="deploymentMode order_request/getDeploymentMode">
    <ConfirmationRequest>
      <ConfirmationHeader tal:attributes="noticeDate python:DateTime().ISO8601(); confirmID here/SaleOrder_getConfirmationRequestConfirmId; type here/SaleOrder_getConfirmationRequestType; operation here/SaleOrder_getConfirmationRequestOperation">
        <IdReference tal:attributes="identifier here/getWoelfelReference" domain="supplierReference"></IdReference>
      </ConfirmationHeader>
      <OrderReference tal:attributes="orderDate python:here.getOrderDate().ISO8601(); orderID here/getDestinationReference">
        <DocumentReference tal:attributes="payloadID here/Order_getPayloadId"></DocumentReference>
      </OrderReference>
      <span tal:omit-tag="" tal:repeat="item here/SaleOrder_getConfirmationItemList">
      <ConfirmationItem tal:attributes="lineNumber item/index; quantity item/order_quantity">
        <UnitOfMeasure>EA</UnitOfMeasure>
        <span tal:omit-tag="" tal:repeat="line item/line_list">
        <ConfirmationStatus tal:attributes="deliveryDate python:line.getStopDate().ISO8601(); quantity line/getQuantity" type="accept">
          <UnitOfMeasure tal:content="line/Movement_getUnitOfMeasure"></UnitOfMeasure>
          <ItemIn tal:condition="python: False" tal:attributes="lineNumber line/getIntIndex; quantity line/getQuantity">
            <ItemID>
              <SupplierPartID tal:content="line/SaleOrderLine_getCxmlSupplierPartId"></SupplierPartID>
              <BuyerPartID  tal:content="python:line.getResourceValue().getDefaultSaleSupplyLineDestinationReference()"></BuyerPartID>
            </ItemID>
            <ItemDetail>
              <UnitPrice>
                <Money tal:attributes="currency line/getPriceCurrencyId" tal:content="line/getPrice"></Money>
              </UnitPrice>
              <Description xml:lang="en" tal:content="line/getDescription"></Description>
              <UnitOfMeasure  tal:content="line/Movement_getUnitOfMeasure"></UnitOfMeasure>
              <PriceBasisQuantity quantity="1" conversionFactor="1">
                <UnitOfMeasure>EA</UnitOfMeasure>
              </PriceBasisQuantity>
              <Classification domain="ERPCommodityCode" tal:content="python: line.getResourceValue().getCxmlClassificationId()"></Classification>
              <Classification domain="ERPCommodityCodeDescription" tal:content="python: line.getResourceValue().getCxmlClassificationTitle()"></Classification>
            </ItemDetail>
          </ItemIn>
        </ConfirmationStatus>
        </span>
      </ConfirmationItem>
      </span>
    </ConfirmationRequest>
  </Request>
</cXML>
</tal:block>